{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evenai.uk/schemas/emergency-rule.schema.json",
  "title": "Emergency routing rule",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "triggers", "response", "priority", "actionId", "source", "approved"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "triggers": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "response": {"type": "string", "minLength": 1},
    "priority": {"type": "integer", "minimum": 1},
    "actionId": {"type": "string"},
    "stopNormalFlow": {"type": "boolean", "const": true},
    "source": {"$ref": "source.schema.json"},
    "approved": {"type": "boolean", "const": true}
  }
}
