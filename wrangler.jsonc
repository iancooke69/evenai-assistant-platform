{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "evenai-ggc-assistant",
  "main": "apps/ggc/worker.mjs",
  "compatibility_date": "2026-07-19",
  "workers_dev": false,
  "vars": {
    "ENABLE_PUBLIC_ASSISTANT": "false",
    "ALLOWED_ORIGINS": "",
    "RATE_LIMIT_RETRY_AFTER_SECONDS": "60"
  }
}
