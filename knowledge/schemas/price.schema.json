{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evenai.uk/schemas/price.schema.json",
  "title": "Deterministic price record",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "serviceId", "currency", "amountMinor", "display", "status", "source", "approved"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "serviceId": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "currency": {"type": "string", "const": "GBP"},
    "amountMinor": {"type": "integer", "minimum": 0},
    "display": {"type": "string", "pattern": "^£[0-9]+(?:\\.[0-9]{2})?$"},
    "status": {"enum": ["active", "inactive", "draft"]},
    "conditions": {"type": "array", "items": {"type": "string"}},
    "source": {"$ref": "source.schema.json"},
    "approved": {"type": "boolean", "const": true}
  }
}
