{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evenai.uk/schemas/faq.schema.json",
  "title": "FAQ record",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "question", "answer", "topics", "source", "approved"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "question": {"type": "string", "minLength": 3},
    "answer": {"type": "string", "minLength": 3},
    "topics": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "source": {"$ref": "source.schema.json"},
    "approved": {"type": "boolean", "const": true}
  }
}
